<%- include('_header', { title: 'Conversations' }) %>

<!-- Page header -->
<div class="page-header">
  <h1 class="page-title">Conversations</h1>
  <p class="page-subtitle">Archive &middot; Search &middot; Export</p>
</div>

<!-- Metrics Strip -->
<div class="metrics-grid">
  <div class="metric-card">
    <div class="metric-value" id="metricConversations">--</div>
    <div class="metric-label">Conversations</div>
  </div>
  <div class="metric-card">
    <div class="metric-value" id="metricStorage">--</div>
    <div class="metric-label">Storage</div>
  </div>
  <div class="metric-card">
    <div class="metric-value" id="metricMessages">--</div>
    <div class="metric-label">Messages</div>
  </div>
  <div class="metric-card">
    <div class="metric-value" id="metricTokens">--</div>
    <div class="metric-label">Est. Tokens</div>
  </div>
</div>
<div id="projectBreakdown" class="project-breakdown"></div>

<div id="app">
  <!-- Toolbar -->
  <div class="toolbar-container">
    <div class="toolbar-controls">
      <!-- Select All -->
      <input type="checkbox" id="selectAllCheckbox" class="select-all-checkbox" title="Select all">

      <!-- Search -->
      <div class="search-wrapper">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
        <input type="text" id="searchInput" placeholder="Search conversations..."
          class="search-input" autocomplete="off" spellcheck="false">
        <kbd class="search-shortcut">&#8984;K</kbd>
      </div>

      <!-- Project filter -->
      <div class="filter-wrapper">
        <select id="projectFilter" class="filter-select">
          <option value="">All projects</option>
          <% projects.forEach(function(p) { %>
            <option value="<%= p %>"><%= p %></option>
          <% }); %>
        </select>
        <svg class="filter-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
      </div>
    </div>

    <!-- Bulk actions -->
    <button id="bulkDeleteBtn" class="bulk-delete-btn hidden">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <polyline points="3,6 5,6 21,6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
      </svg>
      Delete <span id="selectedCount">0</span>
    </button>
  </div>

  <!-- Selection banner -->
  <div id="selectionBanner" class="selection-banner hidden"></div>

  <!-- Stats bar -->
  <div id="statsBar" class="stats-bar"></div>

  <!-- Conversation list -->
  <div id="conversationList" class="conversation-list">
    <div class="loading-state">
      <div class="loading-pulse"></div>
      <span>Loading conversations...</span>
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="pagination-container"></div>
</div>

<%- include('_footer') %>
