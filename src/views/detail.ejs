<%- include('_header', { title: 'Conversation' }) %>

<!-- Conversation header -->
<div class="detail-header">
  <div class="detail-nav">
    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15 18-6-6 6-6"/></svg>
      <span>Back</span>
    </a>
    <div class="detail-divider"></div>
    <span class="project-badge"><%= project %></span>
    <span class="session-id"><%= sessionId.substring(0, 8) %>&hellip;</span>
  </div>
  <div class="detail-exports">
    <a href="/api/conversations/<%= project %>/<%= sessionId %>/export?format=json" class="export-btn">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      JSON
    </a>
    <a href="/api/conversations/<%= project %>/<%= sessionId %>/export?format=md" class="export-btn">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      MD
    </a>
  </div>
</div>

<!-- Messages -->
<div id="messageList" class="message-list"
  data-project="<%= project %>" data-session="<%= sessionId %>">
  <div class="loading-state">
    <div class="loading-pulse"></div>
    <span>Loading messages...</span>
  </div>
</div>

<%- include('_footer') %>
